<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileOrganizer.UI.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource BackgroundBrush}">

    <Page.Resources>
        <DataTemplate x:Key="ActionCardTemplate">
            <Border Width="222" Height="172" Padding="18" Margin="0,0,14,14"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="14"
                                Background="{Binding AccentSurfaceBrush}">
                            <FontIcon Glyph="{Binding Glyph}" FontSize="20"
                                      Foreground="{Binding AccentBrush}"/>
                        </Border>
                        <Border Grid.Column="2" Padding="8,3" CornerRadius="10"
                                Background="{StaticResource SurfaceLightBrush}"
                                Visibility="{Binding BadgeVisibility}">
                            <TextBlock Text="{Binding Badge}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding AccentBrush}"/>
                        </Border>
                    </Grid>
                    <StackPanel Grid.Row="1" Spacing="4">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource PanelTitleTextStyle}"/>
                        <TextBlock Text="{Binding Description}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" MaxLines="3"/>
                    </StackPanel>
                    <TextBlock Grid.Row="2" Text="{Binding ActionText}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding AccentBrush}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ClusterTemplate">
            <Border Width="304" MinHeight="164" Padding="18" Margin="0,0,14,14"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="38" Height="38" CornerRadius="12"
                                Background="{Binding AccentSurfaceBrush}">
                            <FontIcon Glyph="{Binding Glyph}" FontSize="18"
                                      Foreground="{Binding AccentBrush}"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" Style="{StaticResource PanelTitleTextStyle}"/>
                            <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap" MaxLines="4"/>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
        <Grid Padding="32" RowSpacing="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource HeroGradientBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="24" Padding="32">
                <Grid ColumnSpacing="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="328"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="16" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="999"
                                Padding="12,6" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentGreenBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="LOCAL FILE WORKSPACE"
                                           Style="{StaticResource EyebrowTextStyle}"
                                           Foreground="{StaticResource AccentPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Classify, dedupe, and organize files locally."
                                   Style="{StaticResource HeroTextStyle}"
                                   TextWrapping="Wrap" MaxWidth="720"/>
                        <TextBlock Text="Pick a workflow, point at a folder, preview moves before applying. Heavy lifting runs as Python sidecars on your machine."
                                   Style="{StaticResource SubtitleTextStyle}"
                                   TextWrapping="Wrap" MaxWidth="720"/>
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,10,0,0">
                            <Button Content="Open Organize" Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OpenOrganize_Click"/>
                            <Button Content="Cleanup &amp; Duplicates" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="OpenCleanup_Click"/>
                            <Button Content="Browse Toolbox" Style="{StaticResource GhostButtonStyle}"
                                    Click="OpenToolbox_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="20" Padding="22" VerticalAlignment="Stretch">
                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock Text="AT A GLANCE" Style="{StaticResource MetricLabelTextStyle}"/>
                                <TextBlock Text="Workspace behavior" Style="{StaticResource PanelTitleTextStyle}"/>
                            </StackPanel>
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource SurfaceLightBrush}"
                                        CornerRadius="14" Padding="14,12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE73E;" FontSize="15"
                                                  Foreground="{StaticResource AccentGreenBrush}"/>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Preview before move" Style="{StaticResource LabelTextStyle}"/>
                                            <TextBlock Text="Every batch shows the destination tree before files actually move." Style="{StaticResource MutedTextStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Background="{StaticResource SurfaceMutedBrush}"
                                        CornerRadius="14" Padding="14,12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE7A7;" FontSize="15"
                                                  Foreground="{StaticResource AccentBlueBrush}"/>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Full undo log" Style="{StaticResource LabelTextStyle}"/>
                                            <TextBlock Text="Every move is journaled — roll back the last N or the whole run." Style="{StaticResource MutedTextStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Background="{StaticResource SurfaceLightBrush}"
                                        CornerRadius="14" Padding="14,12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE946;" FontSize="15"
                                                  Foreground="{StaticResource AccentOrangeBrush}"/>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Protected paths" Style="{StaticResource LabelTextStyle}"/>
                                            <TextBlock Text="System folders refuse moves at scan, apply, and delete layers." Style="{StaticResource MutedTextStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" Background="{StaticResource SurfaceMutedBrush}"
                                        CornerRadius="14" Padding="14,12">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE72E;" FontSize="15"
                                                  Foreground="{StaticResource AccentGreenBrush}"/>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="No telemetry" Style="{StaticResource LabelTextStyle}"/>
                                            <TextBlock Text="Files and classifications stay on this machine." Style="{StaticResource MutedTextStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}"
                    CornerRadius="20" Padding="14,8">
                <AutoSuggestBox x:Name="TaskSearchBox"
                                PlaceholderText="Search tasks: organize, cleanup, duplicates, photos, watch"
                                QueryIcon="Find"
                                TextChanged="TaskSearchBox_TextChanged"
                                SuggestionChosen="TaskSearchBox_SuggestionChosen"
                                QuerySubmitted="TaskSearchBox_QuerySubmitted">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="4">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
            </Border>

            <StackPanel Grid.Row="2" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Workflows" Style="{StaticResource SectionHeaderTextStyle}"/>
                    <TextBlock Text="Runnable tasks" Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Bottom"/>
                </StackPanel>
                <GridView x:Name="ActionsGrid" SelectionMode="None" IsItemClickEnabled="True"
                          ItemClick="ActionTile_Click"
                          ItemTemplate="{StaticResource ActionCardTemplate}"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Toolbox" Style="{StaticResource SectionHeaderTextStyle}"/>
                    <TextBlock Text="Specialized utilities" Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Bottom"/>
                </StackPanel>
                <GridView x:Name="ClustersGrid" SelectionMode="None" IsItemClickEnabled="True"
                          ItemClick="ClusterTile_Click"
                          ItemTemplate="{StaticResource ClusterTemplate}"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="12"
                        HorizontalAlignment="Center" Margin="0,4,0,0">
                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentGreenBrush}"
                         VerticalAlignment="Center"/>
                <TextBlock Text="FileOrganizer.UI v0.1.0"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center"/>
                <Border Background="{StaticResource DividerBrush}" Width="1" Height="12"
                        VerticalAlignment="Center"/>
                <TextBlock Text="Local-first processing"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center"/>
                <Border Background="{StaticResource DividerBrush}" Width="1" Height="12"
                        VerticalAlignment="Center"/>
                <TextBlock Text="No telemetry"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
