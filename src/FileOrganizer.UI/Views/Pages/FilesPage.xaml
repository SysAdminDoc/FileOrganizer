<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileOrganizer.UI.Views.Pages.FilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">
    <Grid Padding="32" RowSpacing="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Files" Style="{StaticResource TitleTextStyle}"/>
            <TextBlock Style="{StaticResource SubtitleTextStyle}"
                       Text="Sort any folder by file type. No AI in the loop — just extension-based routing into clean buckets like Pictures/JPEGs, Music/Lossless, Documents/PDFs, Archives, Installers."/>
        </StackPanel>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="14">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Source" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="SourceTextBox" Style="{StaticResource PremiumTextBoxStyle}"
                             PlaceholderText="C:\Users\You\Downloads (the messy folder)"/>
                    <Button Grid.Column="2" x:Name="SourceBrowseButton" Content="Browse"
                            Style="{StaticResource SecondaryButtonStyle}" Click="BrowseSource_Click"/>
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Destination" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="DestTextBox" Style="{StaticResource PremiumTextBoxStyle}"
                             PlaceholderText="(leave blank to sort in place — creates buckets next to the files)"/>
                    <Button Grid.Column="2" x:Name="DestBrowseButton" Content="Browse"
                            Style="{StaticResource SecondaryButtonStyle}" Click="BrowseDest_Click"/>
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="What to do" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="ModeCombo" Style="{StaticResource PremiumComboBoxStyle}" HorizontalAlignment="Stretch">
                        <ComboBoxItem Tag="preview" Content="Just show me what would move (preview, safe)" IsSelected="True"/>
                        <ComboBoxItem Tag="apply" Content="Actually sort the files (move into buckets)"/>
                    </ComboBox>
                    <CheckBox Grid.Column="2" x:Name="RecursiveCheck" Content="Subfolders"
                              VerticalAlignment="Center"
                              ToolTipService.ToolTip="Walk into every subfolder. Off = only the immediate folder."/>
                    <Button Grid.Column="3" x:Name="ScanButton" Content="Run"
                            Style="{StaticResource PrimaryButtonStyle}" Click="Run_Click"/>
                    <Button Grid.Column="4" x:Name="CancelButton" Content="Stop"
                            Style="{StaticResource DangerButtonStyle}" IsEnabled="False" Click="Cancel_Click"/>
                </Grid>
            </StackPanel>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource SubtleCardStyle}">
            <Grid ColumnSpacing="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="SCANNED" Style="{StaticResource MetricLabelTextStyle}"/>
                    <TextBlock x:Name="ScannedText" Text="0" Style="{StaticResource MetricNumberTextStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="PLANNED / MOVED" Style="{StaticResource MetricLabelTextStyle}"/>
                    <TextBlock x:Name="MovedText" Text="0"
                               Style="{StaticResource MetricNumberTextStyle}"
                               Foreground="{StaticResource AccentPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="2">
                    <TextBlock Text="ERRORS" Style="{StaticResource MetricLabelTextStyle}"/>
                    <TextBlock x:Name="ErrorsText" Text="0" Style="{StaticResource MetricNumberTextStyle}"
                               Foreground="{StaticResource AccentRedBrush}"/>
                </StackPanel>
                <TextBlock Grid.Column="3" x:Name="StatusText"
                           Text="Idle. Drop a folder in Source above."
                           Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center"
                           HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10" CornerRadius="16,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SOURCE" Style="{StaticResource MetricLabelTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="CATEGORY" Style="{StaticResource MetricLabelTextStyle}"/>
                        <TextBlock Grid.Column="2" Text="DESTINATION" Style="{StaticResource MetricLabelTextStyle}"/>
                    </Grid>
                </Border>
                <ListView x:Name="ResultsList" Grid.Row="1" SelectionMode="None" Padding="0,4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="16,4"/><Setter Property="MinHeight" Value="28"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Source}"
                                           Style="{StaticResource CodeTextStyle}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{Binding Source}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Category}"
                                           Style="{StaticResource CodeTextStyle}"
                                           Foreground="{StaticResource AccentPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Dest}"
                                           Style="{StaticResource CodeTextStyle}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
