<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileOrganizer.UI.Views.Pages.OrganizePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource BackgroundBrush}">

    <Grid Padding="32" RowSpacing="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Organize" Style="{StaticResource TitleTextStyle}"/>
            <TextBlock Text="Drive the AI batch organize pipeline. Preview, plan, apply, and undo classified moves."
                       Style="{StaticResource SubtitleTextStyle}"/>
        </StackPanel>

        <!-- Source picker -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE7C3;" FontSize="16"
                              Foreground="{StaticResource AccentPrimaryBrush}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="Source pipeline"
                               Style="{StaticResource PanelTitleTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ComboBox x:Name="SourceCombo"
                              Style="{StaticResource PremiumComboBoxStyle}"
                              MinWidth="280">
                        <ComboBoxItem Tag="ae" Content="ae — After Effects templates" IsSelected="True"/>
                        <ComboBoxItem Tag="design" Content="design — Design Unorganized folder"/>
                        <ComboBoxItem Tag="design_org" Content="design_org — Design Organized (with legacy hints)"/>
                        <ComboBoxItem Tag="loose_files" Content="loose_files — root-level standalone files"/>
                    </ComboBox>
                </StackPanel>
                <TextBlock Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap"
                           Text="This page drives the design-asset AI batch pipeline (DeepSeek classification → position-based apply → undo journal). Most users want Smart Sort or Files instead — those work on any folder, no AI batch prep needed."/>
            </StackPanel>
        </Border>

        <!-- Action row -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE768;" FontSize="16"
                              Foreground="{StaticResource AccentPrimaryBrush}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="Actions" Style="{StaticResource PanelTitleTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="StatsButton" Content="Show batch stats"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Stats_Click"/>
                    <Button x:Name="PreviewButton" Content="Preview (dry run)"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="Preview_Click"/>
                    <Button x:Name="ValidateButton" Content="Validate sources"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="Validate_Click"/>
                    <Button x:Name="CancelButton" Content="Stop"
                            Style="{StaticResource DangerButtonStyle}"
                            IsEnabled="False"
                            Click="Cancel_Click"/>
                </StackPanel>
                <TextBlock x:Name="StatusText"
                           Text="Idle. Pick a source and run an action."
                           Style="{StaticResource MutedTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Output panel -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,12"
                        CornerRadius="16,16,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE756;" FontSize="14"
                                  Foreground="{StaticResource AccentPrimaryBrush}"/>
                        <TextBlock Text="Output" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="OutputSummary" Text=""
                                   Style="{StaticResource MutedTextStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <ScrollViewer x:Name="OutputScroller"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Padding="20,16">
                    <TextBlock x:Name="OutputBlock"
                               Style="{StaticResource CodeTextStyle}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               IsTextSelectionEnabled="True"
                               Text="No output yet. Click an action above to run a Python script."/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
