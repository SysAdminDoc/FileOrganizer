<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileOrganizer.UI.Views.Pages.WatchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">
    <Grid Padding="32" RowSpacing="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Watch Folders" Style="{StaticResource TitleTextStyle}"/>
            <TextBlock Style="{StaticResource SubtitleTextStyle}"
                       Text="Auto-organize new files as they appear. Each watch is a (source, destination) pair — when a file lands in the source, the same Smart Sort dispatcher routes it to the right bucket in the destination."/>
        </StackPanel>

        <!-- Add a watch -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE710;" FontSize="14"
                              Foreground="{StaticResource AccentPrimaryBrush}"/>
                    <TextBlock Text="Add a watch" Style="{StaticResource PanelTitleTextStyle}"/>
                </StackPanel>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Source" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="NewSrcBox" Style="{StaticResource PremiumTextBoxStyle}"
                             PlaceholderText="C:\Users\You\Downloads"/>
                    <Button Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButtonStyle}"
                            Click="BrowseSrc_Click"/>
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Destination" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="NewDstBox" Style="{StaticResource PremiumTextBoxStyle}"
                             PlaceholderText="C:\Users\You\Organized"/>
                    <Button Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButtonStyle}"
                            Click="BrowseDst_Click"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <CheckBox x:Name="NewCopyCheck" Content="Copy instead of move"/>
                    <Button Content="Add to list" Style="{StaticResource PrimaryButtonStyle}"
                            Click="AddWatch_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Active watches -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE7C8;" FontSize="14"
                              Foreground="{StaticResource AccentPrimaryBrush}"/>
                    <TextBlock Text="Watches" Style="{StaticResource PanelTitleTextStyle}"/>
                    <TextBlock x:Name="WatchCountText" Text="0 configured"
                               Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center"/>
                </StackPanel>
                <ItemsControl x:Name="WatchesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceMutedBrush}"
                                    BorderBrush="{StaticResource DividerBrush}" BorderThickness="1"
                                    CornerRadius="10" Padding="12,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding Src}" Style="{StaticResource CodeTextStyle}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding DestArrow}" Style="{StaticResource CodeTextStyle}"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Tag="{Binding Src}" Click="RemoveWatch_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="Remove"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="StartButton" Content="▶ Start watching"
                            Style="{StaticResource PrimaryButtonStyle}" Click="Start_Click"/>
                    <Button x:Name="StopButton" Content="⏹ Stop"
                            Style="{StaticResource DangerButtonStyle}"
                            IsEnabled="False" Click="Stop_Click"/>
                    <TextBlock x:Name="StatusText"
                               Text="Idle. Add at least one watch, then start."
                               Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource SubtleCardStyle}">
            <Grid ColumnSpacing="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="DETECTED" Style="{StaticResource MetricLabelTextStyle}"/>
                    <TextBlock x:Name="DetectedText" Text="0" Style="{StaticResource MetricNumberTextStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="MOVED" Style="{StaticResource MetricLabelTextStyle}"/>
                    <TextBlock x:Name="MovedText" Text="0"
                               Style="{StaticResource MetricNumberTextStyle}"
                               Foreground="{StaticResource AccentGreenBrush}"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="HeartbeatText"
                           Text=""
                           Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10" CornerRadius="16,16,0,0">
                    <TextBlock Text="LIVE EVENTS" Style="{StaticResource MetricLabelTextStyle}"/>
                </Border>
                <ListView x:Name="EventsList" Grid.Row="1" SelectionMode="None" Padding="0,4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="16,4"/><Setter Property="MinHeight" Value="28"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Time}"
                                           Style="{StaticResource CodeTextStyle}"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Message}"
                                           Style="{StaticResource CodeTextStyle}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding Status}"
                                           Style="{StaticResource CodeTextStyle}"
                                           Foreground="{Binding StatusBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
