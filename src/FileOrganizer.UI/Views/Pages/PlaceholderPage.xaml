<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileOrganizer.UI.Views.Pages.PlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource BackgroundBrush}">

    <Grid Padding="42">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock x:Name="ModuleTitle" Text="Module" Style="{StaticResource TitleTextStyle}"/>
            <TextBlock x:Name="ModuleSubtitle" Text="Module description"
                       Style="{StaticResource SubtitleTextStyle}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,28,0,0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="18" MaxWidth="620">
                <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="48"
                        Width="96" Height="96" HorizontalAlignment="Center">
                    <FontIcon x:Name="ModuleIcon" Glyph="&#xE713;" FontSize="44"
                              Foreground="{StaticResource AccentPrimaryBrush}"/>
                </Border>

                <Border Background="{StaticResource SurfaceWarmBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12,5"
                        HorizontalAlignment="Center">
                    <TextBlock x:Name="StatusBadge" Text="Not available yet"
                               Style="{StaticResource PillTextStyle}"
                               Foreground="{StaticResource AccentYellowBrush}"/>
                </Border>

                <TextBlock x:Name="HeadlineText" Text="Tool not available yet"
                           Style="{StaticResource TitleTextStyle}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="DescriptionText"
                           Text="This route is registered, but its workflow has not been wired into this build."
                           TextAlignment="Center"
                           Style="{StaticResource SubtitleTextStyle}"
                           TextWrapping="Wrap"/>

                <Border x:Name="PoweredByBox" Visibility="Collapsed"
                        Background="{StaticResource SurfaceLightBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="14,10" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE71B;" FontSize="14"
                                  Foreground="{StaticResource AccentGreenBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="PoweredByText" Text=""
                                   Style="{StaticResource MutedTextStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Content="Open Organize"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OpenOrganize_Click"/>
                    <Button Content="Back to Home"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="OpenHome_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
