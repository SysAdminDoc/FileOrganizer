<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileOrganizer.UI.Views.Pages.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource BackgroundBrush}">

    <Grid Padding="32" RowSpacing="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Cleanup" Style="{StaticResource TitleTextStyle}"/>
            <TextBlock Text="Find empty folders, junk files, broken files, big files, and stale downloads. Results stream live as the scanner finds them."
                       Style="{StaticResource SubtitleTextStyle}"/>
        </StackPanel>

        <!-- Inputs -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="14">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Folder"
                               Style="{StaticResource LabelTextStyle}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             x:Name="FolderTextBox"
                             Style="{StaticResource PremiumTextBoxStyle}"
                             PlaceholderText="C:\path\to\folder — paste a path or click Browse"/>
                    <Button Grid.Column="2"
                            x:Name="BrowseButton"
                            Content="Browse"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="Browse_Click"/>
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Scanner"
                               Style="{StaticResource LabelTextStyle}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              x:Name="ScannerCombo"
                              Style="{StaticResource PremiumComboBoxStyle}"
                              SelectionChanged="ScannerCombo_SelectionChanged"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Tag="empty_folders" Content="Empty folders — no files anywhere inside" IsSelected="True"/>
                        <ComboBoxItem Tag="empty_files" Content="Empty (zero-byte) files"/>
                        <ComboBoxItem Tag="temp_files" Content="Temp / junk — .tmp, .bak, Thumbs.db, .DS_Store, partial downloads"/>
                        <ComboBoxItem Tag="broken_files" Content="Broken files — wrong magic bytes / corrupt archives"/>
                        <ComboBoxItem Tag="big_files" Content="Big files — anything above your size threshold"/>
                        <ComboBoxItem Tag="old_downloads" Content="Stale downloads — files not opened in N days"/>
                    </ComboBox>
                    <Button Grid.Column="2"
                            x:Name="ScanButton"
                            Content="Scan"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Scan_Click"/>
                    <Button Grid.Column="3"
                            x:Name="CancelButton"
                            Content="Stop"
                            Style="{StaticResource DangerButtonStyle}"
                            IsEnabled="False"
                            Click="Cancel_Click"/>
                </Grid>
                <!-- Scanner-specific options -->
                <StackPanel x:Name="BigFilesOptions" Orientation="Horizontal" Spacing="10"
                            Visibility="Collapsed">
                    <TextBlock Text="Min size (MB)"
                               Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Center"/>
                    <NumberBox x:Name="MinSizeMbBox" Value="100" Minimum="1" Maximum="100000"
                               SpinButtonPlacementMode="Inline" Width="120"/>
                </StackPanel>
                <StackPanel x:Name="OldDownloadsOptions" Orientation="Horizontal" Spacing="10"
                            Visibility="Collapsed">
                    <TextBlock Text="Days old"
                               Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Center"/>
                    <NumberBox x:Name="DaysOldBox" Value="90" Minimum="1" Maximum="3650"
                               SpinButtonPlacementMode="Inline" Width="120"/>
                </StackPanel>
                <StackPanel x:Name="TempFilesOptions" Orientation="Horizontal" Spacing="14"
                            Visibility="Collapsed">
                    <CheckBox x:Name="IncludeLogsCheck" Content="Include .log files"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Min age (days)"
                                   Style="{StaticResource MutedTextStyle}"
                                   VerticalAlignment="Center"/>
                        <NumberBox x:Name="MinAgeDaysBox" Value="0" Minimum="0" Maximum="3650"
                                   SpinButtonPlacementMode="Inline" Width="100"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel x:Name="BrokenFilesOptions" Orientation="Horizontal" Spacing="14"
                            Visibility="Collapsed">
                    <CheckBox x:Name="CheckArchivesCheck" Content="Validate ZIP/TAR integrity (slower)"
                              IsChecked="True"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status / metrics -->
        <Border Grid.Row="2" Style="{StaticResource SubtleCardStyle}">
            <Grid ColumnSpacing="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="SCANNED" Style="{StaticResource MetricLabelTextStyle}"/>
                    <TextBlock x:Name="ScannedText" Text="0" Style="{StaticResource MetricNumberTextStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="FOUND" Style="{StaticResource MetricLabelTextStyle}"/>
                    <TextBlock x:Name="FoundText" Text="0"
                               Style="{StaticResource MetricNumberTextStyle}"
                               Foreground="{StaticResource AccentPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="2">
                    <TextBlock Text="TOTAL SIZE" Style="{StaticResource MetricLabelTextStyle}"/>
                    <TextBlock x:Name="TotalSizeText" Text="0 B" Style="{StaticResource MetricNumberTextStyle}"/>
                </StackPanel>
                <TextBlock Grid.Column="3"
                           x:Name="StatusText"
                           Text="Idle. Pick a folder and a scanner."
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- Results -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,10"
                        CornerRadius="16,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Path"
                                   Style="{StaticResource MetricLabelTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="SIZE"
                                   Style="{StaticResource MetricLabelTextStyle}"/>
                        <TextBlock Grid.Column="2" Text="REASON"
                                   Style="{StaticResource MetricLabelTextStyle}"/>
                    </Grid>
                </Border>
                <ListView x:Name="ResultsList"
                          Grid.Row="1"
                          SelectionMode="Extended"
                          IsItemClickEnabled="False"
                          Padding="0,4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="16,8"/>
                            <Setter Property="MinHeight" Value="36"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Path}"
                                           Style="{StaticResource CodeTextStyle}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{Binding Path}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SizeText}"
                                           Style="{StaticResource CodeTextStyle}"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Reason}"
                                           Style="{StaticResource CodeTextStyle}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
