<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="FileOrganizer.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Surfaces -->
            <Color x:Key="BrandBackground">#0f1117</Color>
            <Color x:Key="BrandSurface">#1c1f2a</Color>
            <Color x:Key="BrandSurfaceMuted">#15181f</Color>
            <Color x:Key="BrandSurfaceLight">#1f2338</Color>
            <Color x:Key="BrandSurfaceSoft">#162a20</Color>
            <Color x:Key="BrandSurfaceWarm">#1e160a</Color>
            <Color x:Key="BrandSurfaceDanger">#200d0d</Color>
            <Color x:Key="BrandSurfaceInfo">#0c1629</Color>

            <!-- Borders -->
            <Color x:Key="BrandBorder">#252a38</Color>
            <Color x:Key="BrandBorderStrong">#333a52</Color>
            <Color x:Key="BrandDivider">#1a1e2b</Color>

            <!-- Accents — primary swapped to mint-cyan to differentiate from UCX indigo,
                 but matches FileOrganizer's existing Steam Dark cyan accents. -->
            <Color x:Key="BrandAccentPrimary">#22d3ee</Color>
            <Color x:Key="BrandAccentPrimaryHover">#67e8f9</Color>
            <Color x:Key="BrandAccentPrimaryPressed">#0891b2</Color>
            <Color x:Key="BrandAccentBlue">#60a5fa</Color>
            <Color x:Key="BrandAccentCyan">#22d3ee</Color>
            <Color x:Key="BrandAccentGreen">#34d399</Color>
            <Color x:Key="BrandAccentOrange">#fb923c</Color>
            <Color x:Key="BrandAccentYellow">#fbbf24</Color>
            <Color x:Key="BrandAccentRed">#f87171</Color>
            <Color x:Key="BrandAccentViolet">#a78bfa</Color>

            <!-- Text -->
            <Color x:Key="BrandTextPrimary">#e8ecf3</Color>
            <Color x:Key="BrandTextSecondary">#94a3b8</Color>
            <Color x:Key="BrandTextMuted">#6d7d96</Color>
            <Color x:Key="BrandTextSubtle">#4a5568</Color>
            <Color x:Key="BrandTextInverse">#0f172a</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BrandBackground}"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource BrandSurface}"/>
            <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource BrandSurfaceMuted}"/>
            <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource BrandSurfaceLight}"/>
            <SolidColorBrush x:Key="SurfaceSoftBrush" Color="{StaticResource BrandSurfaceSoft}"/>
            <SolidColorBrush x:Key="SurfaceWarmBrush" Color="{StaticResource BrandSurfaceWarm}"/>
            <SolidColorBrush x:Key="SurfaceDangerBrush" Color="{StaticResource BrandSurfaceDanger}"/>
            <SolidColorBrush x:Key="SurfaceInfoBrush" Color="{StaticResource BrandSurfaceInfo}"/>

            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BrandBorder}"/>
            <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BrandBorderStrong}"/>
            <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource BrandDivider}"/>

            <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource BrandAccentPrimary}"/>
            <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource BrandAccentBlue}"/>
            <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource BrandAccentCyan}"/>
            <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource BrandAccentGreen}"/>
            <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource BrandAccentOrange}"/>
            <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource BrandAccentYellow}"/>
            <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource BrandAccentRed}"/>
            <SolidColorBrush x:Key="AccentVioletBrush" Color="{StaticResource BrandAccentViolet}"/>

            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource BrandTextPrimary}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource BrandTextSecondary}"/>
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource BrandTextMuted}"/>
            <SolidColorBrush x:Key="TextSubtleBrush" Color="{StaticResource BrandTextSubtle}"/>
            <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource BrandTextInverse}"/>

            <SolidColorBrush x:Key="OverlayBrush" Color="#b2000000"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"   Color="{StaticResource BrandAccentPrimaryHover}"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush" Color="{StaticResource BrandAccentPrimaryPressed}"/>

            <!-- Gradients -->
            <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f2030" Offset="0"/>
                <GradientStop Color="#0f1520" Offset="0.45"/>
                <GradientStop Color="#0e201c" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AiGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0c1c2a" Offset="0"/>
                <GradientStop Color="#101728" Offset="0.55"/>
                <GradientStop Color="#131922" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="ShellGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a2230" Offset="0"/>
                <GradientStop Color="#161b2e" Offset="0.56"/>
                <GradientStop Color="#14201a" Offset="1"/>
            </LinearGradientBrush>

            <!-- Typography -->
            <Style x:Key="DisplayTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="32"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="LineHeight" Value="40"/>
            </Style>
            <Style x:Key="HeroTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="34"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="LineHeight" Value="42"/>
            </Style>
            <Style x:Key="TitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="LineHeight" Value="30"/>
            </Style>
            <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="LineHeight" Value="24"/>
            </Style>
            <Style x:Key="PanelTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="LineHeight" Value="20"/>
            </Style>
            <Style x:Key="SubtitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="LineHeight" Value="22"/>
            </Style>
            <Style x:Key="BodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="LineHeight" Value="20"/>
            </Style>
            <Style x:Key="MutedTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                <Setter Property="LineHeight" Value="18"/>
            </Style>
            <Style x:Key="LabelTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="LineHeight" Value="20"/>
            </Style>
            <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}"/>
                <Setter Property="LineHeight" Value="16"/>
            </Style>
            <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CharacterSpacing" Value="80"/>
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            </Style>
            <Style x:Key="PillTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CharacterSpacing" Value="20"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            </Style>
            <Style x:Key="CodeTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                <Setter Property="LineHeight" Value="17"/>
            </Style>
            <Style x:Key="MetricNumberTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="26"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="LineHeight" Value="30"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Style>
            <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CharacterSpacing" Value="40"/>
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            </Style>

            <!-- Surfaces -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Padding" Value="20"/>
                <!-- Premium elevation via subtle gradient overlay -->
                <Setter Property="Shadow" Value="{StaticResource CardShadow}"/>
            </Style>
            <Style x:Key="SubtleCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="Padding" Value="16"/>
            </Style>
            <Style x:Key="SectionDividerStyle" TargetType="Border">
                <Setter Property="Height" Value="1"/>
                <Setter Property="Background" Value="{StaticResource DividerBrush}"/>
                <Setter Property="Margin" Value="0,2,0,2"/>
            </Style>
            <Style x:Key="ElevatedPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="18"/>
                <Setter Property="Padding" Value="24"/>
                <Setter Property="Shadow" Value="{StaticResource ElevatedPanelShadow}"/>
            </Style>

            <!-- Buttons -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextInverseBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="MinWidth" Value="104"/>
                <Setter Property="Padding" Value="20,9"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
            </Style>
            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="MinWidth" Value="104"/>
                <Setter Property="Padding" Value="20,9"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
            </Style>
            <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="Padding" Value="14,9"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
            </Style>
            <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{StaticResource SurfaceDangerBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                <Setter Property="BorderBrush" Value="#7f1d1d"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="MinWidth" Value="104"/>
                <Setter Property="Padding" Value="20,9"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
            </Style>
            <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="MinWidth" Value="36"/>
                <Setter Property="Width" Value="36"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="UseSystemFocusVisuals" Value="False"/>
            </Style>

            <!-- Inputs -->
            <Style x:Key="PremiumTextBoxStyle" TargetType="TextBox">
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="12,7"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style x:Key="PremiumComboBoxStyle" TargetType="ComboBox">
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
